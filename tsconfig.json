{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",

    "module": "CommonJS",
    "moduleResolution": "node",

    "target": "ES2020",

    "esModuleInterop": true,
    "strict": true,

    "types": ["node"],

    "skipLibCheck": true,
    "ignoreDeprecations": "6.0",

    "typeRoots": ["./node_modules/@types", "./src/types"],

    "declaration": true,

  },

  "files":["./src/types/express/index.d.ts"],

  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"],
}