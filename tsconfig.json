{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",

    "module": "CommonJS",
    "moduleResolution": "node",

    "target": "ES2020",

    "esModuleInterop": true,
    "strict": true,

    "types": ["node"],

    "skipLibCheck": true,

    "ignoreDeprecations": "6.0"
  },

  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}